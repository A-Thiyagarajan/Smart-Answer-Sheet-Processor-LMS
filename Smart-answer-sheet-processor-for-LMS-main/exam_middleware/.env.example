# ============================================================================
# Smart Answer Sheet Processor for LMS - Environment Configuration
# ============================================================================
# Copy this file to .env and update values for your environment
# CRITICAL: Never commit the actual .env file to version control
# ============================================================================

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
# Debug mode (use False in production)
DEBUG=False

# Unique secret key for JWT token signing (generate a new one for production)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production

# Application metadata (optional)
APP_NAME=Exam Submission Middleware
APP_VERSION=1.0.0

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
# Server bind address (use 0.0.0.0 in production docker, 127.0.0.1 locally)
HOST=0.0.0.0
PORT=8000

# Enable auto-reload on code changes (must be False in production)
RELOAD=False

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# Database mode: "postgres" for production, "sqlite" for development
DATABASE_MODE=postgres

# PostgreSQL Configuration (use when DATABASE_MODE=postgres)
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secure_postgres_password_here
POSTGRES_DB=exam_middleware

# Alternative: Provide full database URL (overrides individual postgres settings)
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/db

# SQLite path (used when DATABASE_MODE=sqlite, ignored when DATABASE_URL is set)
SQLITE_DB_PATH=./exam_middleware.db

# ============================================================================
# REDIS CONFIGURATION (Session & Queue Management)
# ============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Alternative: Provide full Redis URL
# REDIS_URL=redis://password@host:6379/0

# ============================================================================
# MOODLE INTEGRATION (CRITICAL FOR PRODUCTION)
# ============================================================================
# Moodle instance base URL (required in production)
# Example: https://moodle.yourinstitution.edu
MOODLE_BASE_URL=https://your-moodle-instance.com

# Moodle Web Services API Token (required - obtain from Moodle admin panel)
# Steps: Admin → Development → Web services → Tokens → Create token
MOODLE_ADMIN_TOKEN=your-moodle-admin-token-here

# Moodle Web Service Endpoints (usually no need to change)
MOODLE_WS_ENDPOINT=/webservice/rest/server.php
MOODLE_UPLOAD_ENDPOINT=/webservice/upload.php
MOODLE_TOKEN_ENDPOINT=/login/token.php
MOODLE_SERVICE=moodle_mobile_app

# Mock LMS for Testing (set to False in production)
# When enabled, bypasses real Moodle and uses in-memory mock service
MOCK_LMS_ENABLED=False

# ============================================================================
# FILE STORAGE CONFIGURATION
# ============================================================================
# Upload directory for processing exam papers
UPLOAD_DIR=./uploads

# Storage directory for persistent app data
STORAGE_DIR=./storage

# Maximum file size in MB
MAX_FILE_SIZE_MB=50

# Allowed file extensions (comma-separated)
ALLOWED_EXTENSIONS=.pdf,.jpg,.jpeg,.png

# ============================================================================
# ML SERVICE (Optional - for enhanced OCR/document processing)
# ============================================================================
# Set ML_SERVICE_ENABLED=False if not using ML features
ML_SERVICE_ENABLED=False
ML_SERVICE_URL=http://localhost:8501

# ============================================================================
# SUBJECT MAPPING (Configure via database after initial setup)
# ============================================================================
# These can be configured through the API or database admin panel
# Leave as 0 and configure through setup_subject_mapping.py
SUBJECT_19AI405_ASSIGNMENT_ID=0
SUBJECT_19AI411_ASSIGNMENT_ID=0
SUBJECT_ML_ASSIGNMENT_ID=0

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path
LOG_FILE=./logs/app.log

# ============================================================================
# CORS CONFIGURATION (Update with your frontend domain)
# ============================================================================
# JSON array of allowed origins for CORS
# Example for production: ["https://yourdomain.com", "https://admin.yourdomain.com"]
CORS_ORIGINS=["http://localhost:8000"]

# ============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ============================================================================
# Before deploying to production, ensure:
# 
# [ ] DEBUG=False
# [ ] SECRET_KEY is a unique, strong value
# [ ] DATABASE_MODE=postgres with proper credentials
# [ ] DATABASE_URL or all POSTGRES_* variables are set correctly
# [ ] MOODLE_BASE_URL is set to your actual Moodle instance
# [ ] MOODLE_ADMIN_TOKEN is obtained from Moodle admin panel
# [ ] MOCK_LMS_ENABLED=False
# [ ] REDIS_HOST and REDIS_PORT point to production Redis instance
# [ ] CORS_ORIGINS updated with your production domain
# [ ] LOG_LEVEL=WARNING or ERROR (not DEBUG)
# [ ] Using strong passwords for PostgreSQL
# [ ] RELOAD=False
# [ ] HOST=0.0.0.0 (for Docker) or appropriate IP
# [ ] All paths use absolute paths or proper relative references
# 
# Render example values:
# UPLOAD_DIR=/app/data/uploads
# STORAGE_DIR=/app/data/storage
# LOG_FILE=/app/data/logs/app.log
# CORS_ORIGINS=["https://your-service-name.onrender.com"]
#
# ============================================================================
